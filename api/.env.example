PORT=3000
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/<database>

# Mailtrap SMTP settings for password reset emails
MAILTRAP_HOST=live.smtp.mailtrap.io
MAILTRAP_PORT=587
MAILTRAP_USER=your-mailtrap-username
MAILTRAP_PASS=your-mailtrap-password
MAIL_FROM=noreply@yourdomain.com

# Frontend URL used in reset email link
FRONTEND_BASE_URL=https://task-creation-eight.vercel.app/login
